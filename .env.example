# Gemini API Key
GEMINI_API_KEY=your_api_key_here

# Project configuration
AGENT_TIMEOUT_SECONDS=120
MAX_CONCURRENT_AGENTS=3
DEFAULT_MODEL=gemini-3.1-pro-preview
DOCKER_IMAGE_BASE=geminiclaw-agent-base:latest
DOCKER_NETWORK=geminiclaw-net
OUTPUT_BASE_DIR=./outputs
LOG_LEVEL=INFO

# Deep Search Skill (S2)
SKILL_DEEP_SEARCH_ENABLED=false
DEEP_SEARCH_DOMAINS=docs.python.org,arxiv.org
DEEP_SEARCH_MAX_PAGES_PER_DOMAIN=50
DEEP_SEARCH_CACHE_TTL_SECONDS=86400
QDRANT_URL=http://localhost:6333
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Code Execution Skill (S3)
SKILL_CODE_ENABLED=true
CODE_SANDBOX_TIMEOUT_SECONDS=60
CODE_SANDBOX_MEMORY_LIMIT=256m
