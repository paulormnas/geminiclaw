FROM rust:slim AS builder

RUN apt-get update && apt-get install -y \
    build-essential cmake pkg-config \
    libssl-dev git curl \
    protobuf-compiler \
    && rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 https://github.com/qdrant/qdrant.git /qdrant
WORKDIR /qdrant

RUN cargo build --release --no-default-features

FROM debian:trixie-slim
RUN apt-get update && apt-get install -y \
    libssl3 ca-certificates wget \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /qdrant/target/release/qdrant /qdrant/qdrant
COPY --from=builder /qdrant/config /qdrant/config

EXPOSE 6333 6334
WORKDIR /qdrant
ENTRYPOINT ["/qdrant/qdrant"]