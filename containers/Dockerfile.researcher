# Dockerfile para o agente researcher do GeminiClaw
# Stage 1: Builder - Instala nodejs e gemini-cli
FROM geminiclaw-base AS builder
LABEL stage=builder component=agent-researcher

USER root

# Instalar Node.js e ferramentas de build temporárias
RUN apt-get update && apt-get install -y --install-recommends \
    nodejs \
    npm \
    && npm install -g @google/gemini-cli 2>/dev/null || true

# Stage 2: Runtime - Imagem final otimizada baseada no geminiclaw-base
FROM geminiclaw-base AS runtime
LABEL stage=runtime component=agent-researcher

USER root

# Instalar apenas o runtime do Node.js
RUN apt-get update && apt-get install -y --no-install-recommends \
    nodejs \
    && rm -rf /var/lib/apt/lists/*

# Copiar o gemini-cli instalado globalmente da etapa builder
COPY --from=builder /usr/local/lib/node_modules /usr/local/lib/node_modules
COPY --from=builder /usr/local/bin/gemini /usr/local/bin/gemini

# Mudar para o usuário não-root (já configurado no base)
USER appuser

# Comando padrão — executa o agente researcher
CMD ["python", "-m", "agents.researcher.agent"]
